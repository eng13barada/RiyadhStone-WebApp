{
  "name": "riyadhstone-site",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "predev": "npm run ingest:images && npm run guard:imports",
    "guard:tsconfig": "powershell -NoProfile -ExecutionPolicy Bypass -File tools\\guard-tsconfig.ps1",
    "guard:home": "powershell -NoProfile -ExecutionPolicy Bypass -File tools\\guard-home-jsx.ps1",
    "guard:imports": "powershell -NoProfile -ExecutionPolicy Bypass -File tools\\guard-import-header.ps1",
    "ingest:images": "powershell -NoProfile -ExecutionPolicy Bypass -File tools\\rs-ingest-images.ps1",
    "preview:hard": "powershell -NoProfile -ExecutionPolicy Bypass -File tools\\run-preview.ps1",
    "images:auto": "node tools/rs-sd-generate-and-wire.mjs"
  },
  "dependencies": {
    "@fontsource/manrope": "^5.2.8",
    "@gsap/react": "^2.1.2",
    "clsx": "^2.1.0",
    "framer-motion": "^11.0.8",
    "gsap": "^3.12.5",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "tailwind-merge": "^2.2.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.56",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.2.2",
    "vite": "^7.3.1"
  }
}
